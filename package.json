{
  "name": "imessage-chat-builder",
  "version": "1.2.1",
  "description": "Create convincing iMessage prototypes with AI. Turn ideas into iMessage prototypes instantly.",
  "main": "dist/plugin.js",
  "license": "MIT",
  "author": "Patrick Dugan",
  "scripts": {
    "watch": "webpack --mode=development --watch",
    "watch:test": "webpack --mode=development --watch --env testdata",
    "watch:debug": "webpack --mode=development --watch --env debug",
    "build": "webpack --mode=production",
    "update-version": "node dev-scripts/update-version.js",
    "lint:fix": "eslint .",
    "lint:md": "markdownlint '**/*.md' --ignore node_modules",
    "lint:md:fix": "markdownlint '**/*.md' --ignore node_modules --fix",
    "style:write": "prettier --write .",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "setup-hooks": "chmod +x dev-scripts/setup-hooks.sh .githooks/pre-commit && ./dev-scripts/setup-hooks.sh",
    "knip": "knip",
    "prepare": "[ -d .git ] && git config core.hooksPath .githooks || true"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^9.39.3",
    "@figma/eslint-plugin-figma-plugins": "^1.0.0",
    "@figma/plugin-typings": "^1.130.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/typography": "^0.5.20",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "case-sensitive-paths-webpack-plugin": "^2.4.0",
    "clean-webpack-plugin": "^4.0.0",
    "css-loader": "^7.1.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.3",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-testing-library": "^7.16.2",
    "file-loader": "^6.2.0",
    "fork-ts-checker-webpack-plugin": "^9.0.2",
    "globals": "^17.7.0",
    "html-inline-script-webpack-plugin": "^3.2.1",
    "html-webpack-plugin": "^5.6.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "knip": "^5.88.1",
    "lint-staged": "^16.4.0",
    "markdownlint-cli": "^0.49.0",
    "postcss": "^8.5.16",
    "postcss-loader": "^8.2.1",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "style-loader": "^4.0.0",
    "tailwindcss": "^4.2.1",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.2",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.62.1",
    "url-loader": "^4.1.1",
    "webpack": "^5.108.4",
    "webpack-cli": "^6.0.1",
    "webpack-merge": "^6.0.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.110.0",
    "figma-kit": "^1.0.0-beta.23",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^7.18.1",
    "react-textarea-autosize": "^8.5.9"
  }
}
